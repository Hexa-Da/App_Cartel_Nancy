{
  "name": "CumMap",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build && touch dist/.nojekyll",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",
    "android-full-deploy": "npm run build && npx cap sync android && cd android && ./gradlew clean && ./gradlew assembleDebug && adb install -r app/build/outputs/apk/debug/app-debug.apk && cd ..",
    "ios-full-deploy": "npm run build && npx cap sync ios && cd ios/App && xcodebuild clean -workspace App.xcworkspace -scheme App && cd ../.. && npx cap sync ios",
    "sync-android": "npm run build && npx cap sync android",
    "sync-ios": "npm run build && npx cap sync ios",
    "clean-android": "cd android && ./gradlew clean && cd ..",
    "clean-ios": "cd ios/App && xcodebuild clean -workspace App.xcworkspace -scheme App && cd ../..",
    "rebuild-android": "npm run clean-android && npm run sync-android",
    "rebuild-ios": "npm run clean-ios && npm run sync-ios",
    "build-android-release": "npm run build && npx cap sync android && cd android && ./gradlew clean && ./gradlew bundleRelease && cd ..",
    "build-android-apk": "npm run build && npx cap sync android && cd android && ./gradlew clean && ./gradlew assembleRelease && cd .."
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.2",
    "@capacitor/browser": "^6.0.5",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/geolocation": "^6.1.0",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/keyboard": "^6.0.3",
    "@capacitor/local-notifications": "^6.1.2",
    "@capacitor/push-notifications": "^6.0.4",
    "@capacitor/screen-orientation": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@emailjs/browser": "^4.4.1",
    "@expo/vector-icons": "^14.1.0",
    "@firebase/auth": "^1.10.0",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-navigation/native": "^7.1.6",
    "@types/leaflet": "^1.9.8",
    "@types/react-ga": "^2.3.0",
    "@types/react-native-web": "^0.19.1",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-window": "^1.8.8",
    "@types/uuid": "^10.0.0",
    "firebase": "^11.6.0",
    "html2canvas": "^1.4.1",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-ga": "^3.3.1",
    "react-ga4": "^2.1.0",
    "react-icons": "^5.5.0",
    "react-leaflet": "^4.2.1",
    "react-native-maps": "^1.22.6",
    "react-native-web": "^0.20.0",
    "react-router-dom": "^7.6.0",
    "react-window": "^2.1.0",
    "react-window-infinite-loader": "^1.0.10",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "firebase-tools": "^14.24.1",
    "gh-pages": "^6.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^5.2.0"
  }
}
