rules_version = '2';

// Règles de sécurité Firebase Storage pour Cartel Nancy
service firebase.storage {
  match /b/{bucket}/o {
    // Règles pour les fichiers de planning
    match /planningFiles/{fileName} {
      // Permettre la lecture à tous les utilisateurs
      allow read: if true;
      
      // Permettre l'écriture et la suppression à tous les utilisateurs
      // (pour les plannings seulement, pas d'authentification requise)
      allow write, delete: if true;
    }
    
    // Règles par défaut : refuser tout le reste
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
